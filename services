<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Services | Inaya Solution Desk</title>
<meta name="description" content="Networking, e-commerce, technical writing, and document refinement services. Honest scoping, real solutions, patient guidance included with every project.">
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self';">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<style>
:root {
  --cream: #F5F5EE;
  --sage-pale: #E8EBD5;
  --sage-soft: #C5C8A3;
  --sage-fresh: #9EAE97;
  --olive-warm: #8F967B;
  --earth-taupe: #776B54;
  --espresso: #3D3527;
  --gold-muted: #B8956A;
  --white: #FFFFFF;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--cream);
  color: var(--espresso);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  line-height: 1.7;
}
a { text-decoration: none; color: inherit; }

/* ================= NAVBAR ================= */
.page-nav-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20px 16px 0;
  background: linear-gradient(180deg, rgba(245, 245, 238, 0.95) 0%, rgba(245, 245, 238, 0.7) 100%);
  backdrop-filter: blur(20px);
}
@media (min-width: 640px) { .page-nav-wrap { padding: 20px 24px 0; } }
@media (min-width: 768px) { .page-nav-wrap { padding: 20px 40px 0; } }
@media (min-width: 1024px) { .page-nav-wrap { padding: 20px 64px 0; } }

.navbar {
  border-radius: 100px;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  max-width: 1400px;
  margin: 0 auto;
  background: rgba(61, 53, 39, 0.85);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(158, 174, 151, 0.3);
  box-shadow: 0 10px 40px rgba(119, 107, 84, 0.15);
}
@media (min-width: 768px) { .navbar { padding: 14px 28px; } }

.navbar .brand {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  font-weight: 700;
  font-style: italic;
  letter-spacing: -0.01em;
  white-space: nowrap;
  background: linear-gradient(135deg, #F5F5EE 0%, #E8EBD5 50%, #C5C8A3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
@media (min-width: 480px) { .navbar .brand { font-size: 18px; } }
@media (min-width: 768px) { .navbar .brand { font-size: 22px; } }

.nav-links { display: none; gap: 32px; list-style: none; }
@media (min-width: 900px) { .nav-links { display: flex; } }
.nav-links a {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: rgba(245, 245, 238, 0.85);
  transition: color 0.3s;
  position: relative;
  letter-spacing: 0.3px;
}
.nav-links a::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -6px;
  width: 0;
  height: 2px;
  background: var(--sage-fresh);
  transition: all 0.3s;
  transform: translateX(-50%);
  border-radius: 2px;
}
.nav-links a:hover, .nav-links a.active { color: var(--sage-fresh); }
.nav-links a:hover::after, .nav-links a.active::after { width: 100%; }

.nav-toggle {
  background: rgba(245, 245, 238, 0.1);
  border: 1px solid rgba(245, 245, 238, 0.2);
  color: var(--cream);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.nav-toggle:hover { background: rgba(158, 174, 151, 0.3); border-color: var(--sage-fresh); }
@media (min-width: 900px) { .nav-toggle { display: none; } }

.mobile-menu {
  position: fixed;
  top: 0;
  right: -100%;
  width: 85%;
  max-width: 320px;
  height: 100vh;
  background: linear-gradient(180deg, rgba(61, 53, 39, 0.98) 0%, rgba(119, 107, 84, 0.98) 100%);
  backdrop-filter: blur(30px);
  border-left: 1px solid rgba(245, 245, 238, 0.1);
  z-index: 1000;
  padding: 100px 32px 40px;
  transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: -20px 0 60px rgba(0,0,0,0.5);
}
.mobile-menu.open { right: 0; }
.mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.mobile-menu ul li a {
  display: block;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 20px;
  font-weight: 500;
  color: rgba(245, 245, 238, 0.9);
  padding: 16px 0;
  border-bottom: 1px solid rgba(245, 245, 238, 0.1);
  transition: all 0.3s;
}
.mobile-menu ul li a:hover, .mobile-menu ul li a.active { color: var(--sage-fresh); padding-left: 12px; }
.mobile-menu-close {
  position: absolute;
  top: 24px;
  right: 24px;
  background: rgba(245, 245, 238, 0.1);
  border: 1px solid rgba(245, 245, 238, 0.15);
  color: var(--cream);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mobile-menu-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(61, 53, 39, 0.6);
  backdrop-filter: blur(4px);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 999;
}
.mobile-menu-backdrop.open { opacity: 1; visibility: visible; }

/* ================= PAGE HERO ================= */
.page-hero {
  padding: 80px 20px 100px;
  background: linear-gradient(135deg, var(--cream) 0%, var(--sage-pale) 50%, #DDE0C0 100%);
  position: relative;
  overflow: hidden;
  text-align: center;
}
@media (min-width: 768px) { .page-hero { padding: 120px 40px 140px; } }
.page-hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(158, 174, 151, 0.25) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.page-hero::after {
  content: '';
  position: absolute;
  bottom: -100px; left: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(184, 149, 106, 0.2) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.section-eyebrow {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  color: var(--earth-taupe);
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin-bottom: 20px;
  padding: 8px 18px;
  background: rgba(143, 150, 123, 0.15);
  border: 1px solid rgba(143, 150, 123, 0.3);
  border-radius: 100px;
  position: relative;
  z-index: 2;
}
@media (min-width: 640px) { .section-eyebrow { font-size: 12px; letter-spacing: 3px; padding: 8px 20px; } }

.page-hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: 40px;
  font-weight: 600;
  line-height: 1.1;
  color: var(--espresso);
  margin-bottom: 24px;
  letter-spacing: -0.02em;
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
  position: relative;
  z-index: 2;
}
@media (min-width: 640px) { .page-hero h1 { font-size: 54px; } }
@media (min-width: 1024px) { .page-hero h1 { font-size: 72px; } }
.page-hero h1 em {
  font-style: italic;
  font-weight: 500;
  background: linear-gradient(135deg, var(--olive-warm) 0%, var(--earth-taupe) 60%, var(--gold-muted) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.page-hero .subtitle {
  font-family: 'Inter', sans-serif;
  font-size: 17px;
  font-weight: 300;
  color: var(--earth-taupe);
  max-width: 640px;
  margin: 0 auto;
  line-height: 1.75;
  position: relative;
  z-index: 2;
}
@media (min-width: 640px) { .page-hero .subtitle { font-size: 19px; } }

.container-max { max-width: 1200px; margin: 0 auto; }

/* ================= SERVICES SECTION ================= */
.services-section {
  padding: 100px 20px;
  background: var(--cream);
}
@media (min-width: 640px) { .services-section { padding: 120px 32px; } }
@media (min-width: 1024px) { .services-section { padding: 140px 64px; } }

.service-block {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: center;
  margin-bottom: 100px;
  padding-bottom: 100px;
  border-bottom: 1px solid rgba(158, 174, 151, 0.25);
}
.service-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
@media (min-width: 900px) { .service-block { grid-template-columns: 1fr 1fr; gap: 80px; } }
@media (min-width: 900px) { .service-block.reverse .service-visual { order: 2; } }

.service-visual {
  aspect-ratio: 1;
  border-radius: 32px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cream);
  padding: 40px;
  box-shadow: 0 30px 80px rgba(119, 107, 84, 0.25);
}
.service-visual.v1 { background: linear-gradient(135deg, var(--sage-fresh) 0%, var(--olive-warm) 60%, var(--earth-taupe) 100%); }
.service-visual.v2 { background: linear-gradient(135deg, var(--gold-muted) 0%, var(--earth-taupe) 60%, var(--espresso) 100%); }
.service-visual.v3 { background: linear-gradient(135deg, var(--olive-warm) 0%, var(--earth-taupe) 100%); }
.service-visual.v4 { background: linear-gradient(135deg, var(--sage-soft) 0%, var(--sage-fresh) 50%, var(--olive-warm) 100%); }
.service-visual::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 30%, rgba(245, 245, 238, 0.3) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(0, 0, 0, 0.2) 0%, transparent 50%);
}
.service-visual-content { position: relative; z-index: 2; text-align: center; }
.service-visual-content .big-icon { font-size: 100px; margin-bottom: 20px; opacity: 0.95; }
.service-visual-content .service-number {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: 4px;
  opacity: 0.8;
  margin-bottom: 8px;
}
.service-visual-content .service-name {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 28px;
  font-weight: 500;
  line-height: 1.2;
}

.service-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  font-weight: 600;
  color: var(--espresso);
  margin-bottom: 18px;
  line-height: 1.15;
  letter-spacing: -0.02em;
}
@media (min-width: 640px) { .service-content h2 { font-size: 42px; } }
.service-content h2 em {
  font-style: italic;
  font-weight: 500;
  color: var(--earth-taupe);
}
.service-content .lead {
  font-size: 16px;
  color: var(--earth-taupe);
  line-height: 1.75;
  margin-bottom: 28px;
  font-weight: 300;
}
@media (min-width: 640px) { .service-content .lead { font-size: 17px; } }

.included-list { list-style: none; margin-bottom: 32px; }
.included-list li {
  display: flex;
  gap: 12px;
  padding: 10px 0;
  color: var(--espresso);
  font-size: 15px;
  align-items: flex-start;
}
.included-list li i {
  color: var(--sage-fresh);
  font-size: 18px;
  flex-shrink: 0;
  margin-top: 2px;
}

.pricing-preview {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin-bottom: 28px;
  padding: 20px;
  background: linear-gradient(135deg, rgba(158, 174, 151, 0.1) 0%, rgba(184, 149, 106, 0.05) 100%);
  border: 1px solid rgba(158, 174, 151, 0.25);
  border-radius: 16px;
}
.tier {
  text-align: center;
  padding: 14px 8px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.55);
  transition: all 0.3s;
}
.tier:hover { background: rgba(255, 255, 255, 0.9); transform: translateY(-3px); }
.tier .tier-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--earth-taupe);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.tier .tier-price {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--espresso);
}
.tier.premium .tier-price {
  background: linear-gradient(135deg, var(--olive-warm), var(--gold-muted));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.service-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 30px;
  background: linear-gradient(135deg, var(--olive-warm), var(--earth-taupe));
  color: var(--cream);
  border-radius: 100px;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 600;
  font-size: 14px;
  transition: all 0.3s;
  border: none;
}
.service-cta:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(119, 107, 84, 0.35);
  color: var(--cream);
}

/* ================= PROCESS SECTION ================= */
.process-section {
  padding: 100px 20px;
  background: linear-gradient(180deg, var(--cream) 0%, var(--sage-pale) 100%);
  position: relative;
}
@media (min-width: 640px) { .process-section { padding: 120px 32px; } }
@media (min-width: 1024px) { .process-section { padding: 140px 64px; } }

.section-header { text-align: center; margin-bottom: 60px; }
.section-header .title {
  font-family: 'Playfair Display', serif;
  font-size: 36px;
  font-weight: 600;
  color: var(--espresso);
  margin-bottom: 16px;
  line-height: 1.15;
  letter-spacing: -0.02em;
}
@media (min-width: 640px) { .section-header .title { font-size: 48px; } }
.section-header .title em {
  font-style: italic;
  font-weight: 500;
  background: linear-gradient(135deg, var(--olive-warm) 0%, var(--gold-muted) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.section-header .subtitle {
  font-size: 16px;
  color: var(--earth-taupe);
  max-width: 640px;
  margin: 0 auto;
  font-weight: 300;
}
@media (min-width: 640px) { .section-header .subtitle { font-size: 18px; } }

.process-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
  margin-top: 50px;
}
@media (min-width: 640px) { .process-grid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 1024px) { .process-grid { grid-template-columns: repeat(4, 1fr); } }

.process-step {
  background: rgba(255, 255, 255, 0.75);
  border: 1px solid rgba(158, 174, 151, 0.3);
  border-radius: 20px;
  padding: 36px 26px;
  text-align: center;
  transition: all 0.4s;
  position: relative;
}
.process-step:hover {
  transform: translateY(-6px);
  border-color: var(--sage-fresh);
  box-shadow: 0 25px 50px rgba(119, 107, 84, 0.15);
}
.step-number {
  position: absolute;
  top: 20px; right: 24px;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 40px;
  font-weight: 600;
  color: var(--sage-fresh);
  opacity: 0.4;
  line-height: 1;
}
.step-icon {
  width: 56px; height: 56px;
  background: linear-gradient(135deg, var(--sage-fresh), var(--olive-warm));
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  font-size: 24px;
  margin: 0 auto 22px;
  box-shadow: 0 10px 30px rgba(143, 150, 123, 0.3);
}
.process-step h4 {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 22px;
  font-weight: 600;
  color: var(--espresso);
  margin-bottom: 12px;
}
.process-step p {
  font-size: 14.5px;
  color: var(--earth-taupe);
  line-height: 1.7;
}

/* ================= FAQ ================= */
.faq-section {
  padding: 100px 20px;
  background: var(--cream);
}
@media (min-width: 640px) { .faq-section { padding: 120px 32px; } }
@media (min-width: 1024px) { .faq-section { padding: 140px 64px; } }

.faq-list { max-width: 820px; margin: 60px auto 0; display: flex; flex-direction: column; gap: 12px; }
.faq-item {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(158, 174, 151, 0.3);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s;
}
.faq-item.open { border-color: var(--sage-fresh); background: rgba(255, 255, 255, 0.95); }
.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 26px;
  cursor: pointer;
  transition: all 0.3s;
  gap: 20px;
}
.faq-question h4 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--espresso);
  flex: 1;
}
@media (min-width: 640px) { .faq-question h4 { font-size: 17px; } }
.faq-toggle {
  width: 32px; height: 32px;
  background: linear-gradient(135deg, var(--sage-fresh), var(--olive-warm));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  font-size: 16px;
  flex-shrink: 0;
  transition: transform 0.3s;
}
.faq-item.open .faq-toggle { transform: rotate(45deg); }
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, padding 0.4s ease;
  padding: 0 26px;
}
.faq-item.open .faq-answer {
  max-height: 500px;
  padding: 0 26px 26px;
}
.faq-answer p {
  font-size: 15px;
  color: var(--earth-taupe);
  line-height: 1.75;
}

/* ================= CTA ================= */
.cta-section {
  padding: 100px 20px;
  background: linear-gradient(135deg, var(--olive-warm) 0%, var(--earth-taupe) 100%);
  text-align: center;
  position: relative;
  overflow: hidden;
}
@media (min-width: 640px) { .cta-section { padding: 120px 32px; } }
.cta-section::before {
  content: '';
  position: absolute;
  top: -200px; left: 50%;
  transform: translateX(-50%);
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(245, 245, 238, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.cta-inner { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }
.cta-section .eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--sage-soft);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 24px;
  display: inline-block;
  padding: 8px 20px;
  background: rgba(245, 245, 238, 0.1);
  border: 1px solid rgba(245, 245, 238, 0.2);
  border-radius: 100px;
}
.cta-section h2 {
  font-family: 'Playfair Display', serif;
  font-size: 36px;
  font-weight: 600;
  color: var(--cream);
  margin-bottom: 24px;
  line-height: 1.15;
  letter-spacing: -0.02em;
}
@media (min-width: 640px) { .cta-section h2 { font-size: 52px; } }
.cta-section h2 em {
  font-style: italic;
  font-weight: 500;
  background: linear-gradient(135deg, var(--sage-pale) 0%, var(--sage-soft) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.cta-section p {
  font-size: 17px;
  color: rgba(245, 245, 238, 0.85);
  margin-bottom: 40px;
  font-weight: 300;
  line-height: 1.75;
}
.cta-buttons {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}
.btn-primary {
  font-family: 'Space Grotesk', sans-serif;
  background: var(--cream);
  color: var(--espresso);
  padding: 14px 32px;
  border-radius: 100px;
  font-weight: 600;
  font-size: 14px;
  transition: all 0.3s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
}
.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(245, 245, 238, 0.35);
  background: var(--white);
}
.btn-ghost {
  font-family: 'Space Grotesk', sans-serif;
  background: transparent;
  color: var(--cream);
